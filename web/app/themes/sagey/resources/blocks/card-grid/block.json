{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sage/card-grid",
  "title": "Card Grid",
  "description": "A responsive grid of cards — image, title, body, and optional link. Configurable column count.",
  "category": "sagey",
  "icon": "grid-view",
  "keywords": ["cards", "grid", "features", "services"],
  "textdomain": "sage",
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "html": false
  },
  "acf": {
    "mode": "preview",
    "renderCallback": "App\\Blocks\\CardGrid::render"
  }
}
