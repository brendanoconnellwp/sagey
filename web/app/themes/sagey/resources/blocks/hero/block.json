{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sage/hero",
  "title": "Hero",
  "description": "A full-width hero with heading, subheading, and call-to-action.",
  "category": "sagey",
  "icon": "cover-image",
  "keywords": ["hero", "banner", "intro"],
  "textdomain": "sage",
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "html": false,
    "jsx": true
  },
  "acf": {
    "mode": "preview",
    "renderCallback": "App\\Blocks\\Hero::render"
  }
}
